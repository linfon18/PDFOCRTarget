<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:PDFOCRTarget.ViewModels.Pages"
             xmlns:models="using:PDFOCRTarget.Models"
             xmlns:icons="using:Material.Icons.Avalonia"
             mc:Ignorable="d" d:DesignWidth="880" d:DesignHeight="640"
             x:Class="PDFOCRTarget.Views.Pages.OcrPage"
             x:DataType="vm:OcrPageViewModel">

  <UserControl.Styles>
    <Style Selector="Button.icon-btn">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="6"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="MinHeight" Value="32"/>
      <Setter Property="CornerRadius" Value="8"/>
    </Style>
    <Style Selector="Button.icon-btn:pointerover">
      <Setter Property="Background" Value="#15FFFFFF"/>
    </Style>
  </UserControl.Styles>

  <Grid RowDefinitions="Auto,Auto,*,Auto">
    <!-- 标题 + 工具栏 -->
    <Border Grid.Row="0" Background="#20000000" Padding="24,16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Spacing="4">
          <TextBlock Text="OCR 文字识别" FontSize="24" FontWeight="Bold"
                     Foreground="{DynamicResource MaterialOnBackgroundBrush}"/>
          <TextBlock Text="支持 PDF 扫描件、PNG、JPG 等图片格式" FontSize="13" Opacity="0.7"
                     Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
        </StackPanel>

        <!-- 操作按钮 -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
          <Button Classes="icon-btn" Command="{Binding AddFilesCommand}" ToolTip.Tip="添加文件">
            <icons:MaterialIcon Kind="Plus" Width="20" Height="20"
                                Foreground="{DynamicResource MaterialPrimaryBrush}"/>
          </Button>
          <Button Classes="icon-btn" Command="{Binding ClearFilesCommand}" ToolTip.Tip="清空列表">
            <icons:MaterialIcon Kind="DeleteOutline" Width="20" Height="20"
                                Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
          </Button>
          <Border Width="1" Height="24" Background="#15FFFFFF" Margin="4,0"/>
          <Button Classes="icon-btn" Command="{Binding CopyTextCommand}" ToolTip.Tip="复制文本">
            <icons:MaterialIcon Kind="ContentCopy" Width="20" Height="20"
                                Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
          </Button>
          <Button Classes="icon-btn" Command="{Binding ExportTextCommand}" ToolTip.Tip="导出文本">
            <icons:MaterialIcon Kind="Export" Width="20" Height="20"
                                Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- 选项栏 -->
    <Border Grid.Row="1" Background="#10000000" Padding="24,10">
      <StackPanel Orientation="Horizontal" Spacing="16" VerticalAlignment="Center">
        <TextBlock Text="OCR 引擎: Python RapidOCR (中英文自动识别)" FontSize="13" Opacity="0.7"
                   Foreground="{DynamicResource MaterialOnSurfaceBrush}" VerticalAlignment="Center"/>
      </StackPanel>
    </Border>

    <!-- 文件列表 + 文本预览 -->
    <Grid Grid.Row="2" ColumnDefinitions="*,*">
      <!-- 文件列表 -->
      <Border Grid.Column="0" Background="#08000000" Padding="12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="文件列表" FontSize="14" FontWeight="SemiBold"
                     Margin="4,0,0,8" Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
          <ListBox ItemsSource="{Binding FileItems}"
                   SelectedItem="{Binding SelectedFileItem}"
                   Background="Transparent"
                   ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemTemplate>
              <DataTemplate x:DataType="models:FileItem">
                <Border Background="#10FFFFFF" CornerRadius="8" Padding="10,8" Margin="0,2"
                        BorderBrush="#08FFFFFF" BorderThickness="1">
                  <Grid ColumnDefinitions="*,Auto,Auto">
                    <StackPanel Grid.Column="0" Spacing="2">
                      <TextBlock Text="{Binding FileName}" FontSize="13" FontWeight="Medium"
                                 Foreground="{DynamicResource MaterialOnSurfaceBrush}"
                                 TextTrimming="CharacterEllipsis"/>
                      <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding FileType}" FontSize="11" Opacity="0.5"
                                   Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
                        <TextBlock Text="{Binding FileSizeText}" FontSize="11" Opacity="0.5"
                                   Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
                      </StackPanel>
                    </StackPanel>
                    <TextBlock Grid.Column="1" Text="{Binding Status}" FontSize="11" Opacity="0.7"
                               VerticalAlignment="Center" Margin="8,0"
                               Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
                    <Button Grid.Column="2" Classes="icon-btn" Width="24" Height="24"
                            Command="{Binding $parent[ListBox].((vm:OcrPageViewModel)DataContext).RemoveFileCommand}"
                            CommandParameter="{Binding}">
                      <icons:MaterialIcon Kind="Close" Width="14" Height="14" Opacity="0.5"
                                          Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
                    </Button>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListBox.ItemTemplate>
          </ListBox>
        </DockPanel>
      </Border>

      <!-- 文本预览 -->
      <Border Grid.Column="1" Background="#08000000" Padding="12">
        <DockPanel>
          <TextBlock DockPanel.Dock="Top" Text="识别结果" FontSize="14" FontWeight="SemiBold"
                     Margin="4,0,0,8" Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
          <TextBox Text="{Binding PreviewText}"
                   IsReadOnly="True" AcceptsReturn="True" TextWrapping="Wrap"
                   Background="Transparent" FontSize="13"
                   Foreground="{DynamicResource MaterialOnSurfaceBrush}"/>
        </DockPanel>
      </Border>
    </Grid>

    <!-- 底部状态栏 + 进度 -->
    <Border Grid.Row="3" Background="#20000000" Padding="24,10">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
          <TextBlock Text="{Binding StatusText}" FontSize="13" Opacity="0.8"
                     Foreground="{DynamicResource MaterialOnSurfaceBrush}" VerticalAlignment="Center"/>
          <ProgressBar Value="{Binding ProgressValue}" Maximum="100" Width="200" Height="6"
                       CornerRadius="3" IsVisible="{Binding IsProcessing}"/>
          <TextBlock Text="{Binding ProgressText}" FontSize="12" Opacity="0.6"
                     IsVisible="{Binding IsProcessing}"
                     Foreground="{DynamicResource MaterialOnSurfaceBrush}" VerticalAlignment="Center"/>
        </StackPanel>
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8">
          <Button Command="{Binding StartOcrCommand}" IsVisible="{Binding !IsProcessing}" Height="32"
                  Classes="accent" CornerRadius="16" Padding="16,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <icons:MaterialIcon Kind="Play" Width="16" Height="16" VerticalAlignment="Center"/>
              <TextBlock Text="开始识别" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
          <Button Command="{Binding StopOcrCommand}" IsVisible="{Binding IsProcessing}" Height="32"
                  CornerRadius="16" Padding="16,0">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <icons:MaterialIcon Kind="Stop" Width="16" Height="16" VerticalAlignment="Center"/>
              <TextBlock Text="停止" FontSize="13" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</UserControl>
